# -----------------------------------------------------------------------------
# Distributor inventory sync credentials
# -----------------------------------------------------------------------------
# Copy this file to .env (or export these vars in your shell) once you have
# live integration credentials from your distributor reps. Until then,
# sync falls back to CSV files under integrations/.

# --- CORS / cross-origin callers (Shopify embed) -----------------------------
# Comma-separated list of origins allowed to call /api/* from the browser.
# Leave unset locally; set on the deployed backend when embedding into
# Shopify. Use * only for quick testing.
# ALLOWED_ORIGINS=https://your-store.myshopify.com,https://your-store.com

# --- Cheney Brothers (CB Direct EDI / data feed) -----------------------------
# Request via your Cheney account rep. Typical channel is EDI 846 over AS2/SFTP.
CHENEY_API_URL=
CHENEY_API_KEY=
CHENEY_CUSTOMER_ID=

# --- US Foods (MOXē / EDI 846) -----------------------------------------------
# Request via your US Foods rep or the US Foods EDI onboarding team.
USFOODS_API_URL=
USFOODS_API_KEY=
USFOODS_ACCOUNT_ID=

# --- Microsoft 365 mailbox (preferred email source) --------------------------
# OAuth 2.0 client-credentials flow against Microsoft Graph.
#
# One-time Azure setup (portal.azure.com, admin account):
#   1. Microsoft Entra ID -> App registrations -> New registration
#      Name: "Inventory Tracker Mail Scanner"
#      Accounts: "Accounts in this organizational directory only"
#   2. API permissions -> Add a permission -> Microsoft Graph ->
#      Application permissions -> Mail.Read
#      (also Mail.ReadWrite if you enable MS365_MARK_READ=1)
#      then click "Grant admin consent for <tenant>"
#   3. Certificates & secrets -> New client secret -> copy the Value column
#      immediately (not the Secret ID; the Value is only shown once)
#
# Where each value lives in Azure Portal:
#   MS365_TENANT_ID     Microsoft Entra ID -> Overview -> Tenant ID
#   MS365_CLIENT_ID     App registrations -> your app -> Overview ->
#                       Application (client) ID
#   MS365_CLIENT_SECRET your app -> Certificates & secrets -> the "Value"
#                       of the client secret you created (copy immediately)
#   MS365_USER          M365 admin center -> Users -> Active users ->
#                       the mailbox's UPN (e.g. ops@your-bakery.com).
#                       Comma-separate to scan multiple mailboxes in one
#                       pass, e.g. "ops@your-bakery.com,orders@your-bakery.com".
#                       All listed mailboxes must live in the same tenant.
#   MS365_FOLDER        optional; mailbox folder to scan (default: Inbox)
#
# Deploying on Render: set these as Environment Variables on the service
# (Dashboard -> your service -> Environment -> Add Environment Variable).
# Do NOT commit the real values to this file; .env is gitignored.
MS365_TENANT_ID=
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=
MS365_USER=                 # mailbox UPN, e.g. ops@your-bakery.com
MS365_FOLDER=Inbox
# Optional: override the Graph $filter (default: unread only)
# MS365_FILTER=isRead eq false and receivedDateTime ge 2025-01-01T00:00:00Z
# MS365_MARK_READ=1          # mark processed messages as read

# --- Generic IMAP fallback (non-Microsoft mailboxes) -------------------------
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_IMAP_USER=ops@your-bakery.com
# EMAIL_IMAP_PASSWORD=        # app password, not your login password
# EMAIL_IMAP_FOLDER=INBOX
# EMAIL_IMAP_SEARCH=(UNSEEN SINCE 1-Jan-2025)
# EMAIL_IMAP_MARK_READ=1

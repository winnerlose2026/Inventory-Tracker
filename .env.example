# -----------------------------------------------------------------------------
# Distributor inventory sync credentials
# -----------------------------------------------------------------------------
# Copy this file to .env (or export these vars in your shell) once you have
# live integration credentials from your distributor reps. Until then,
# sync falls back to CSV files under integrations/.

# --- CORS / cross-origin callers (Shopify embed) -----------------------------
# Comma-separated list of origins allowed to call /api/* from the browser.
# Leave unset locally; set on the deployed backend when embedding into
# Shopify. Use * only for quick testing.
# ALLOWED_ORIGINS=https://your-store.myshopify.com,https://your-store.com

# --- Cheney Brothers (CB Direct EDI / data feed) -----------------------------
# Request via your Cheney account rep. Typical channel is EDI 846 over AS2/SFTP.
CHENEY_API_URL=
CHENEY_API_KEY=
CHENEY_CUSTOMER_ID=

# --- US Foods (MOXē / EDI 846) -----------------------------------------------
# Request via your US Foods rep or the US Foods EDI onboarding team.
USFOODS_API_URL=
USFOODS_API_KEY=
USFOODS_ACCOUNT_ID=

# --- Microsoft 365 mailbox (preferred email source) --------------------------
# OAuth 2.0 client-credentials flow against Microsoft Graph. In Azure AD:
#   1. App registrations -> New registration
#   2. API permissions -> Microsoft Graph -> Application permissions ->
#      Mail.Read  (and Mail.ReadWrite if you enable MS365_MARK_READ=1)
#   3. Grant admin consent on the tenant
#   4. Certificates & secrets -> New client secret -> copy value below
MS365_TENANT_ID=
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=
MS365_USER=                 # mailbox UPN, e.g. ops@your-bakery.com
MS365_FOLDER=Inbox
# Optional: override the Graph $filter (default: unread only)
# MS365_FILTER=isRead eq false and receivedDateTime ge 2025-01-01T00:00:00Z
# MS365_MARK_READ=1          # mark processed messages as read

# --- Generic IMAP fallback (non-Microsoft mailboxes) -------------------------
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_IMAP_USER=ops@your-bakery.com
# EMAIL_IMAP_PASSWORD=        # app password, not your login password
# EMAIL_IMAP_FOLDER=INBOX
# EMAIL_IMAP_SEARCH=(UNSEEN SINCE 1-Jan-2025)
# EMAIL_IMAP_MARK_READ=1
